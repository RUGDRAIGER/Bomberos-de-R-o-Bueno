# Copiar a web/.env.local (no subir a git) y completar con Settings → API de Supabase.
VITE_SUPABASE_URL=https://TU_REF.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_desde_dashboard_settings_api

# Opcional — enlace directo a un APK publicado (p. ej. GitHub Releases, Drive con enlace público)
# VITE_ANDROID_APK_URL=https://ejemplo.com/releases/pof.apk

# Opcional — cuando exista app nativa en App Store o TestFlight
# VITE_IOS_APP_URL=https://apps.apple.com/app/idXXXXXXXX
